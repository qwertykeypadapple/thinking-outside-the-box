# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — block .env / .env.local / etc.; allow .env.example as a template
.env*
!.env.example

# vercel
.vercel

# sentry — created by withSentryConfig source-map upload, holds SENTRY_AUTH_TOKEN
.env.sentry-build-plugin

# typescript
*.tsbuildinfo
next-env.d.ts
