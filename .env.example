# Copy to .env.local and fill in. Never commit .env.local.

# >=32 chars. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
COOKIE_SECRET=

# "mlx" (local, default), "anthropic" (production), or "claude-code"
# (local dev only — shells out to the `claude` CLI).
LLM_PROVIDER=mlx

# MLX server defaults — run via mlx_lm.server
MLX_BASE_URL=http://localhost:8080/v1
MLX_MODEL=mlx-community/Qwen3.5-9B-OptiQ-4bit

# Anthropic (when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Claude Code headless (when LLM_PROVIDER=claude-code). LOCAL DEV ONLY —
# the Render container has no `claude` binary and no OAuth keychain. Uses
# your Claude Code subscription instead of the API. Pick `sonnet` / `haiku`
# / `opus` or a full model ID. No env key needed (auth flows through the
# same login the `claude` CLI uses).
CLAUDE_CODE_MODEL=sonnet

# --- Supabase ---
# From Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Secret key bypasses RLS — server-only. Never prefix with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=

# --- Embeddings (optional; tag-overlap fallback when unset) ---
# Get a key at https://dash.voyageai.com
VOYAGE_API_KEY=
# VOYAGE_MODEL=voyage-3

# --- Moderation ---
# Handle granted access to the /reports admin page. Leave unset to disable.
ADMIN_HANDLE=

# --- Donation channel URLs (PLAN §7.1) ---
# Public URLs shown on /sponsors. Leave unset until approvals finalize — the
# UI then shows them as "pending approval" with disabled CTA buttons.
NEXT_PUBLIC_GITHUB_SPONSORS_URL=
NEXT_PUBLIC_OPEN_COLLECTIVE_URL=

# --- LLM spend kill-switch (PLAN §7.2) ---
# Daily Anthropic spend caps (USD). When today's accumulated spend reaches the
# HARD limit, /api/chat returns 429 until UTC midnight. Soft is informational
# (shown on /insights). Defaults are PLAN.md targets and apply when unset.
# Set LLM_KILLSWITCH_DISABLED=1 to bypass entirely (useful for tests/dev).
LLM_DAILY_SOFT_LIMIT_USD=15
LLM_DAILY_HARD_LIMIT_USD=25

# --- Cloudflare Turnstile (invisible human check) ---
# Get keys at https://dash.cloudflare.com → Turnstile → Add Site.
# When TURNSTILE_SECRET_KEY is unset, all bot checks soft-bypass (dev mode).
# Cloudflare also publishes always-pass test keys for local dev:
#   sitekey: 1x00000000000000000000AA
#   secret:  1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Sentry (optional; SDK no-ops when DSN is unset) ---
# From sentry.io → your project → Settings → Client Keys (DSN).
# Same DSN value goes in both — the NEXT_PUBLIC_ prefix exposes it to the
# browser SDK; the server reads SENTRY_DSN.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Build-time source-map upload — needed so prod stack traces aren't minified.
# Create at https://sentry.io/settings/auth-tokens/ with project:releases + org:read scopes.
# Set on Render/host build env; keep out of git (.env.sentry-build-plugin is gitignored).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
